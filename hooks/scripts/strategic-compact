#!/bin/bash
# STRATEGIC COMPACT HOOK
# Runs before every Edit and Write tool call. Tracks how many edits have
# happened this session and suggests /compact at strategic checkpoints.
# Uses PPID (parent process ID) as a session identifier.
# Never blocks — only suggests via stderr.
#
# Configuration:
#   COMPACT_THRESHOLD  — number of edits before first suggestion (default: 50)

THRESHOLD="${COMPACT_THRESHOLD:-50}"

# Clamp threshold to a sane range
if [ "$THRESHOLD" -lt 1 ] 2>/dev/null || [ "$THRESHOLD" -gt 10000 ] 2>/dev/null; then
  THRESHOLD=50
fi

# Session-scoped counter file (keyed to parent PID)
COUNTER_FILE="${TMPDIR:-/tmp}/claude-compact-${PPID}"

# Read and increment counter atomically enough for our purposes
COUNT=0
if [ -f "$COUNTER_FILE" ]; then
  COUNT=$(cat "$COUNTER_FILE" 2>/dev/null || echo 0)
fi
COUNT=$((COUNT + 1))
echo "$COUNT" > "$COUNTER_FILE"

# Suggest at the threshold, then every 25 calls after
if [ "$COUNT" -eq "$THRESHOLD" ]; then
  echo "[team-plugin] ${COUNT} edits this session — consider running /compact before continuing to a new phase." >&2
elif [ "$COUNT" -gt "$THRESHOLD" ]; then
  OVER=$((COUNT - THRESHOLD))
  if [ $((OVER % 25)) -eq 0 ]; then
    echo "[team-plugin] ${COUNT} edits this session — good checkpoint for /compact if context feels stale." >&2
  fi
fi

exit 0
